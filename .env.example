MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=retail-demand-forecasting
MLFLOW_REGISTERED_MODEL_NAME=retail-demand-forecast
FORECAST_HORIZON=28
REORDER_SERVICE_LEVEL=0.95

# Databricks option
# Set these when you want MLflow runs logged to your Databricks workspace.
# MLFLOW_TRACKING_URI=databricks
# DATABRICKS_HOST=https://<your-workspace-host>
# DATABRICKS_TOKEN=<your-personal-access-token>
# DATABRICKS_EXPERIMENT_PATH=/Shared/retail-demand-forecasting
